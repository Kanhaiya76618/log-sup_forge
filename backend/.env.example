# Copy to .env (gitignored). OWNER: P1. Never commit real keys.

# Groq LLM for planner framing + verifier critic (optional — deterministic
# heuristics take over when unset). Get a key at https://console.groq.com
GROQ_API_KEY=gsk_xxxx

# Live data layer: 1 = pull real Open-Meteo weather for the port network
# (no API key needed), 0/unset = synthetic generator.
FLOWFORGE_LIVE=1

# Scale live weather thresholds (0.3 = trip on calm days for demos; 1.0 = honest).
DEMO_SENSITIVITY=1.0

# 1 = inject one clearly-labeled synthetic disruption when live weather is calm.
FLOWFORGE_FORCE_DEMO=0

# 1 = also scan Google News RSS (keyless) for port-disruption headlines; matched
# ports join the weather blocked-union. Degrades silently if the feed is down.
FLOWFORGE_NEWS=1

# HITL gate: auto-execute only above this confidence and below this cost.
AUTO_APPROVE_CONFIDENCE=0.80
MAX_AUTO_COST=5000
